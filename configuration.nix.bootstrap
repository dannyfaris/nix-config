# nixos-vm — bootstrap configuration (SUPERSEDED)
# This file is kept as a reference. The active config is now flake-based.
# See CLAUDE.md for repo-level documentation and TODO.md for the roadmap.

{ config, lib, pkgs, ... }:

let
  # Public key from the Mac dev machine. Used as the sole SSH credential
  # for the user below — password auth is disabled.
  macSshKey = "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIPNUroaa0Z3VyMJVnnQWTtuaosFL30E6xDsSUEAuS8MI daniel.faris@gotaxi.co.nz";
in
{
  imports = [ ./hardware-configuration.nix ];

  # --- Boot
  boot.loader.systemd-boot.enable = true;
  boot.loader.efi.canTouchEfiVariables = true;

  # --- Networking
  networking.hostName = "nixos-vm";
  networking.networkmanager.enable = true;
  networking.firewall.enable = true;

  # --- Locale
  time.timeZone = "Pacific/Auckland";
  i18n.defaultLocale = "en_NZ.UTF-8";

  # --- Nix daemon settings
  nix.settings = {
    experimental-features = [ "nix-command" "flakes" ];

    # Hardlink-dedupe /nix/store on write. Small write-time cost, meaningful
    # disk savings over months. Safe to leave on.
    auto-optimise-store = true;

    # Flake repos under active development are dirty most of the time;
    # the warning becomes pure noise. Deliberate, do not re-enable.
    warn-dirty = false;
  };

  nix.gc = {
    automatic = true;
    dates = "weekly";
    options = "--delete-older-than 30d";
  };

  # command-not-found looks up suggestions in a programs.sqlite that
  # flake-based NixOS does not generate. Leaving it enabled means it
  # silently fails. Off is honest. Do not re-enable without also
  # arranging for the index to be built.
  programs.command-not-found.enable = false;

  # Whitelist unfree packages by name. Adding to this list should be a
  # deliberate decision; the build will fail loudly if a new unfree
  # package tries to slip in. Do NOT replace with `allowUnfree = true`.
  nixpkgs.config.allowUnfreePredicate = pkg:
    builtins.elem (lib.getName pkg) [
      "claude-code"
    ];

  # --- SSH: hardened from boot one
  # Key-only, no root, no password fallback, no keyboard-interactive.
  # Break-glass is the UTM console (see header).
  services.openssh = {
    enable = true;
    openFirewall = true;
    settings = {
      PasswordAuthentication = false;
      KbdInteractiveAuthentication = false;
      PermitRootLogin = "no";
    };
  };

  # --- Users: fully declarative
  # mutableUsers = false makes this file the sole source of truth for user
  # state. `passwd` changes do not persist across nixos-rebuild. To rotate
  # the password: regenerate the hash with `mkpasswd -m sha-512`, update
  # below, commit, rebuild. This is the keystone of declarative user
  # management — do not relax.
  users.mutableUsers = false;
  users.users.dbf = {
    isNormalUser = true;
    description = "Daniel";
    extraGroups = [ "wheel" "networkmanager" ];

    # SHA-512 hash, committed to the repo. Salted and slow to reverse —
    # acceptable for a private repo during bootstrap, NOT acceptable
    # long-term.
    # TODO (after flake conversion): switch to hashedPasswordFile via
    # sops-nix or agenix. See header item #2.
    hashedPassword = "REDACTED_HASH";

    openssh.authorizedKeys.keys = [ macSshKey ];
  };

  # --- System packages
  # Only true system-administration tools belong here. Application and
  # user-tier tools should live in home-manager once the flake conversion
  # lands. claude-code is here for bootstrap so it's available on first
  # boot to drive the rest of the setup.
  environment.systemPackages = with pkgs; [
    git
    vim
    curl

    # TODO (flake conversion): relocate to home-manager. See header item #1.
    claude-code
  ];

  # stateVersion pins the *defaults of stateful services* to a release.
  # This is NOT the running NixOS version. Set once at install; never
  # change, even after upgrading the system to a newer release.
  system.stateVersion = "25.11";
}
