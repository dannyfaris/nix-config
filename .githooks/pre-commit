#!/usr/bin/env bash
# Pre-commit hook — enforces ADR-023's "do not hand-edit
# hardware-configuration.nix" convention.
#
# Each hosts/<name>/hardware-configuration.nix must carry either:
#   - the stub form's banner ("AUTO-GENERATED by nixos-anywhere"),
#     present in the pre-bootstrap stub before nixos-anywhere first
#     runs; or
#   - nixos-generate-config's own banner ("Do not modify this file"),
#     present after nixos-anywhere --generate-hardware-config overwrites
#     the stub during install.
#
# A staged file lacking both is assumed to have been hand-edited and the
# commit is blocked. Override (e.g. for legitimate one-off fixes) with:
#   git commit --no-verify
#
# Install via: just install-hooks (sets core.hooksPath to .githooks/).
# See docs/decisions/ADR-023 for the why.

set -euo pipefail

# --diff-filter=ACMRT: Added, Copied, Modified, Renamed, Typechange.
# Including R catches "rename to hardware-configuration.nix from
# something else" which would otherwise bypass the banner check.
staged=$(git diff --cached --name-only --diff-filter=ACMRT \
    | grep -E '^hosts/[^/]+/hardware-configuration\.nix$' || true)

if [[ -z "$staged" ]]; then
    exit 0
fi

failures=0
while IFS= read -r file; do
    # head -n 20 gives the banner room to live; both expected forms are
    # at the very top of the file. 2>/dev/null in case the file is
    # newly-staged but deleted on disk.
    if ! head -n 20 "$file" 2>/dev/null \
        | grep -qE 'AUTO-GENERATED by nixos-anywhere|Do not modify this file'; then
        echo "ERROR: $file is missing the auto-generated banner." >&2
        echo "  Per ADR-023, hardware-configuration.nix must be auto-generated, not hand-edited." >&2
        echo "  Regenerate via:" >&2
        echo "    nixos-anywhere --generate-hardware-config nixos-generate-config \\" >&2
        echo "                   $file" >&2
        failures=$((failures + 1))
    fi
done <<< "$staged"

if [[ $failures -gt 0 ]]; then
    echo >&2
    echo "$failures hardware-configuration.nix file(s) failed the banner check." >&2
    echo "Override (intentional hand-edit): git commit --no-verify" >&2
    exit 1
fi

exit 0
